<div class="custom-step-container"
    style="display: flex; flex-direction: column; gap: 8px; background: rgba(0,0,0,0.2); padding: 12px; border-radius: 4px; border: 1px solid rgba(255,255,255,0.1);">

    {{!-- Card A: Foundry Audio --}}
    <div style="border:1px solid rgba(255,255,255,0.12); border-radius:4px; overflow:hidden;">

        <div class="foundry-toggle"
            style="display:flex; align-items:center; justify-content:space-between; padding:10px 14px; background:rgba(255,255,255,0.04); cursor:pointer; user-select:none; color:rgba(255,255,255,0.85); font-size:0.9em;">
            <span><i class="fas fa-volume-up" style="margin-right:8px; opacity:0.7;"></i>Foundry VTT Audio — local and
                bundled sounds</span>
            <i class="fas fa-chevron-{{#if hasToken}}right{{else}}down{{/if}} foundry-chevron"
                style="opacity:0.4; font-size:0.8em;"></i>
        </div>

        <div class="foundry-section"
            style="display:{{#if hasToken}}none{{else}}flex{{/if}}; flex-direction:column; gap:10px; padding:12px 14px; border-top:1px solid rgba(255,255,255,0.06);">
            <button type="button" class="skip-provider-btn"
                style="width:100%; padding:8px 14px; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.18); color:rgba(255,255,255,0.8); border-radius:3px; cursor:pointer; font-size:0.9em;">
                Foundry Audio Only →
            </button>
        </div>

    </div>

    {{!-- Card B: Syrinscape --}}
    <div style="border:1px solid rgba(139,92,246,0.3); border-radius:4px; overflow:hidden;">

        <div class="syrin-toggle"
            style="display:flex; align-items:center; justify-content:space-between; padding:10px 14px; background:rgba(139,92,246,0.06); cursor:pointer; user-select:none; color:rgba(255,255,255,0.85); font-size:0.9em;">
            <span><i class="fas fa-plug" style="margin-right:8px; color:#a78bfa;"></i>Syrinscape <span
                    style="opacity:0.55;">(optional)</span> — extend with cloud-hosted sounds</span>
            <i class="fas fa-chevron-{{#if expandSyrin}}down{{else}}right{{/if}} syrin-chevron"
                style="opacity:0.5; font-size:0.8em;"></i>
        </div>

        <div class="syrin-section"
            style="display:{{#if expandSyrin}}flex{{else}}none{{/if}}; flex-direction:column; gap:14px; padding:14px; border-top:1px solid rgba(139,92,246,0.15);">

            <label style="display:block; font-weight:bold; font-size:0.9em; margin:0;">
                Auth Token <span style="opacity:0.5; font-weight:normal;">(optional)</span>
            </label>

            <div style="display:flex; gap:5px; align-items:stretch;">
                <input type="password" name="authToken" class="attunement-token-input" value="{{token}}"
                    placeholder="Paste token here…"
                    style="flex:1; box-sizing:border-box; background:rgba(255,255,255,0.05); color:#fff; border:1px solid rgba(255,255,255,0.15); padding:8px 10px; border-radius:3px;">
                <button type="button" class="toggle-visibility"
                    style="flex:0 0 36px; align-self:stretch; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.15); border-radius:3px; cursor:pointer;">
                    <i class="fas fa-eye"></i>
                </button>
            </div>

            <button type="button" class="verify-syrinscape-btn"
                style="width:100%; padding:8px 12px; background:rgba(139,92,246,0.2); border:1px solid #7c3aed; color:#c4b5fd; border-radius:3px; cursor:pointer; font-weight:bold;">
                <i class="fas fa-plug"></i> Verify &amp; Connect Syrinscape
            </button>

            {{#if mismatch}}
            <div
                style="padding:8px 10px; background:rgba(234,179,8,0.12); border:1px solid #facc15; border-radius:3px; color:#facc15; font-size:0.85em;">
                <i class="fas fa-exclamation-triangle"></i> <strong>Token Mismatch</strong> — Verification will
                synchronize Resonance and Syrinscape Control.
            </div>
            {{/if}}

            {{#if hasSyrinControl}}
            <div
                style="padding:8px 10px; background:rgba(34,211,238,0.07); border:1px solid rgba(34,211,238,0.25); border-radius:3px; font-size:0.85em; color:#cffafe; line-height:1.4;">
                <i class="fas fa-link" style="color:#22d3ee;"></i> <strong style="color:#22d3ee;">Syrinscape Control
                    detected.</strong>
                A token is still required so Resonance can read your library metadata.
            </div>
            {{/if}}

            <p
                style="font-size:0.85em; opacity:0.7; margin:0; padding-top:2px; border-top:1px solid rgba(255,255,255,0.06);">
                Find your token: <a href="https://syrinscape.com/online/cp/" target="_blank"
                    style="color:#a29bfe;">Syrinscape Control Panel</a> → Your Game → Show Auth Token.
            </p>

        </div>

    </div>

</div>