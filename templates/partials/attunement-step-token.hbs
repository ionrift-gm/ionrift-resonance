<div class="custom-step-container"
    style="display: flex; flex-direction: column; gap: 12px; background: rgba(0,0,0,0.2); padding: 12px; border-radius: 4px; border: 1px solid rgba(255,255,255,0.1);">

    {{!-- Path A: Skip (local-only) --}}
    <div
        style="padding: 10px; background: rgba(74,222,128,0.08); border: 1px solid rgba(74,222,128,0.3); border-radius: 4px;">
        <p style="margin: 0 0 8px 0; font-size: 0.9em; color: #d1fae5;">
            <i class="fas fa-box-open" style="color:#4ade80;"></i>
            <strong style="color:#4ade80;">Using the Ionrift SFX Pack?</strong>
            No token needed — click below to proceed.
        </p>
        <button type="button" class="skip-provider-btn"
            style="width:100%; padding: 7px 12px; background: rgba(74,222,128,0.15); border: 1px solid #4ade80; color:#4ade80; border-radius:3px; cursor:pointer; font-weight:bold;">
            <i class="fas fa-forward"></i> Skip — Use Local Sounds Only
        </button>
    </div>

    {{!-- Divider --}}
    <div style="display:flex; align-items:center; gap:8px; opacity:0.5; font-size:0.8em;">
        <hr style="flex:1; border-color: rgba(255,255,255,0.15); margin:0;">
        or connect Syrinscape
        <hr style="flex:1; border-color: rgba(255,255,255,0.15); margin:0;">
    </div>

    {{!-- Path B: Syrinscape token --}}
    <label style="display:block; font-weight:bold; font-size:0.9em;">
        Syrinscape Auth Token <span style="opacity:0.5; font-weight:normal;">(optional)</span>
    </label>
    <div style="display:flex; gap:5px;">
        <input type="password" name="authToken" class="attunement-token-input" value="{{token}}"
            placeholder="Paste token here…"
            style="flex:1; box-sizing:border-box; background:rgba(255,255,255,0.05); color:#fff; border:1px solid rgba(255,255,255,0.2); padding:8px; border-radius:3px;">
        <button type="button" class="toggle-visibility"
            style="flex:0 0 30px; padding:0; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.2); border-radius:3px;">
            <i class="fas fa-eye"></i>
        </button>
    </div>

    {{#if mismatch}}
    <div
        style="padding:8px; background:rgba(234,179,8,0.15); border:1px solid #facc15; border-radius:4px; color:#facc15; font-size:0.9em;">
        <i class="fas fa-exclamation-triangle"></i> <strong>Token Mismatch</strong> — Verification will synchronize
        Resonance and Syrinscape Control.
    </div>
    {{/if}}

    {{#if hasSyrinControl}}
    <div
        style="padding:8px; background:rgba(34,211,238,0.08); border:1px solid rgba(34,211,238,0.3); border-radius:4px; font-size:0.85em; color:#cffafe;">
        <i class="fas fa-link" style="color:#22d3ee;"></i> <strong style="color:#22d3ee;">Syrinscape Control
            detected.</strong>
        A token is still required so Resonance can read your library metadata.
    </div>
    {{/if}}

    <p style="font-size:0.8em; opacity:0.6; margin:0;">
        Find your token: <a href="https://syrinscape.com/online/cp/" target="_blank" style="color:#a29bfe;">Syrinscape
            Control Panel</a> → Your Game → Show Auth Token.
    </p>
</div>