<div class="custom-step-container"
    style="display: flex; flex-direction: column; gap: 15px; background: rgba(0,0,0,0.2); padding: 15px; border-radius: 4px; border: 1px solid rgba(255,255,255,0.1);{{#if isLocked}} opacity:0.55; pointer-events:none;{{/if}}">

    {{#if isLocked}}
    <div
        style="padding:8px 10px; background:rgba(234,179,8,0.08); border:1px solid rgba(234,179,8,0.3); border-radius:3px; font-size:0.85em; color:#fde68a;">
        <i class="fas fa-lock"></i> Complete the <strong>Sound Provider</strong> step first.
    </div>
    {{/if}}

    {{#if hasPacks}}
    {{!-- Packs installed: show green status --}}
    <div style="display: flex; align-items: center; gap: 12px; padding: 12px; background: rgba(74,222,128,0.06); border: 1px solid rgba(74,222,128,0.2); border-radius: 6px;">
        <i class="fas fa-check-circle" style="font-size: 2em; color: #4ade80; flex-shrink: 0;"></i>
        <div style="flex: 1;">
            <strong style="color: #4ade80; display: block; margin-bottom: 3px; font-size: 1.1em;">
                Sound Packs Ready
            </strong>
            <span style="font-size: 0.9em; opacity: 0.9; line-height: 1.4; display: block; color: #ddd;">
                {{enabledCount}} pack{{#unless singlePack}}s{{/unless}} enabled with {{bindingCount}} sound bindings.
            </span>
        </div>
    </div>

    {{!-- Per-pack detail --}}
    <div style="display: flex; flex-direction: column; gap: 6px; padding: 0 4px;">
        {{#each packs}}
        {{#if this.enabled}}
        <div style="display: flex; align-items: center; gap: 10px; padding: 6px 10px; background: rgba(255,255,255,0.03); border-radius: 4px;">
            <i class="fas fa-music" style="color: #58a6ff; font-size: 0.9em;"></i>
            <span style="flex: 1; color: #c9d1d9; font-size: 0.9em;">
                {{this.name}} <span style="color: #8b949e; font-size: 0.85em;">v{{this.version}}</span>
            </span>
            <span style="color: #8b949e; font-size: 0.8em;">{{this.bindingCount}} keys</span>
        </div>
        {{/if}}
        {{/each}}
    </div>

    <button type="button" class="sound-packs-continue-btn" {{#if isLocked}}disabled{{/if}}
        style="width:100%; padding:7px 12px; background:rgba(74,222,128,0.15); border:1px solid rgba(74,222,128,0.3); color:#4ade80; border-radius:3px; cursor:pointer; font-weight:bold;">
        <i class="fas fa-check"></i> Continue
    </button>

    {{else}}
    {{!-- No packs: show nudge --}}
    <div style="display: flex; align-items: flex-start; gap: 12px; padding: 12px; background: rgba(234,179,8,0.06); border: 1px solid rgba(234,179,8,0.2); border-radius: 6px;">
        <i class="fas fa-box-open" style="font-size: 2em; color: #fbbf24; flex-shrink: 0; margin-top: 2px;"></i>
        <div style="flex: 1;">
            <strong style="color: #fbbf24; display: block; margin-bottom: 3px; font-size: 1.1em;">
                No Sound Packs Installed
            </strong>
            <span style="font-size: 0.9em; opacity: 0.9; line-height: 1.4; display: block; color: #ddd;">
                Download the Core SFX Pack to hear combat, spells, and creature sounds. Then import the <code>.zip</code> file using the button below.
            </span>
        </div>
    </div>

    <div style="display: flex; gap: 8px;">
        <button type="button" class="sound-packs-download-btn"
            style="flex: 1; padding: 7px 12px; background: rgba(88,166,255,0.15); border: 1px solid rgba(88,166,255,0.3); color: #58a6ff; border-radius: 3px; cursor: pointer; font-weight: bold;">
            <i class="fas fa-download"></i> Get Core SFX Pack
        </button>
        <button type="button" class="sound-packs-import-btn"
            style="flex: 1; padding: 7px 12px; background: rgba(139,92,246,0.15); border: 1px solid rgba(139,92,246,0.3); color: #a78bfa; border-radius: 3px; cursor: pointer; font-weight: bold;">
            <i class="fas fa-file-import"></i> Import .zip
        </button>
    </div>

    <button type="button" class="sound-packs-continue-btn" {{#if isLocked}}disabled{{/if}}
        style="width:100%; padding:7px 12px; background:rgba(139,92,246,0.2); border:1px solid #7c3aed; color:#c4b5fd; border-radius:3px; cursor:pointer; font-weight:bold;">
        <i class="fas fa-forward"></i> Skip — I'll set up packs later
    </button>
    {{/if}}
</div>