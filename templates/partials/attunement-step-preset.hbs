<div class="custom-step-container"
    style="display: flex; flex-direction: column; gap: 15px; background: rgba(0,0,0,0.2); padding: 15px; border-radius: 4px; border: 1px solid rgba(255,255,255,0.1);">

    <div style="display: flex; flex-direction: column; gap: 10px;">

        {{!-- Local SFX Pack --}}
        <label
            style="display:flex; align-items:flex-start; gap:15px; cursor:pointer; padding: 8px; border-radius: 4px; transition: background 0.2s; background: rgba(255,255,255,0.03);">
            <input type="radio" name="preset" value="pack" {{#if (eq defaultPreset "pack" )}}checked{{/if}}
                style="margin-top: 4px; transform: scale(1.5); accent-color: #4ade80; cursor: pointer;">
            <div style="flex: 1;">
                <strong style="color: #4ade80; display: block; margin-bottom: 3px; font-size: 1.1em;">
                    <i class="fas fa-box-open"></i> Ionrift SFX Pack
                    {{#if isFirstSetup}}<span
                        style="font-size:0.8em; opacity:0.7; font-weight:normal;">(Recommended)</span>{{/if}}
                </strong>
                <span style="font-size: 0.9em; opacity: 0.9; line-height: 1.4; display: block; color: #ddd;">
                    370+ sounds across combat, weapons, spells, and system events.
                </span>
            </div>
        </label>

        {{!-- Keep Current --}}
        <label
            style="display:flex; align-items:flex-start; gap:15px; cursor:pointer; padding: 8px; border-radius: 4px; transition: background 0.2s; background: rgba(255,255,255,0.03);">
            <input type="radio" name="preset" value="keep" {{#if (eq defaultPreset "keep" )}}checked{{/if}}
                style="margin-top: 4px; transform: scale(1.5); accent-color: #9b59b6; cursor: pointer;">
            <div style="flex: 1;">
                <strong style="color: #fff; display: block; margin-bottom: 3px; font-size: 1.1em;">Keep Current
                    Configuration</strong>
                <span style="font-size: 0.9em; opacity: 0.9; line-height: 1.4; display: block; color: #ddd;">
                    Preserve your existing sound bindings and overrides.
                </span>
            </div>
        </label>

        {{!-- Standard (Manual) --}}
        <label
            style="display:flex; align-items:flex-start; gap:15px; cursor:pointer; padding: 8px; border-radius: 4px; transition: background 0.2s; background: rgba(255,255,255,0.03);">
            <input type="radio" name="preset" value="empty" {{#if (eq defaultPreset "empty" )}}checked{{/if}}
                style="margin-top: 4px; transform: scale(1.5); accent-color: #9b59b6; cursor: pointer;">
            <div style="flex: 1;">
                <strong style="color: #fff; display: block; margin-bottom: 3px; font-size: 1.1em;">Standard Setup
                    (Manual)</strong>
                <span style="font-size: 0.9em; opacity: 0.9; line-height: 1.4; display: block; color: #ddd;">
                    Initialize with a clean slate. Bring your own sounds via the Calibration UI.
                </span>
            </div>
        </label>

    </div>

    <button type="button" class="apply-preset-btn"
        style="width:100%; padding:7px 12px; background:rgba(139,92,246,0.2); border:1px solid #7c3aed; color:#c4b5fd; border-radius:3px; cursor:pointer; font-weight:bold;">
        <i class="fas fa-check"></i> Apply Selection
    </button>

</div>