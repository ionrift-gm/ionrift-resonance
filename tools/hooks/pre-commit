#!/bin/sh
# .git/hooks/pre-commit
# Installed by: node tools/install-hooks.mjs
# Checks staged files for hardcoded absolute local paths before commit.

# Locate repo root (works even when called from a subdirectory).
ROOT=$(git rev-parse --show-toplevel)

# Run the path hygiene check if the script exists.
CHECKER="$ROOT/tools/check-local-paths.mjs"
if [ -f "$CHECKER" ]; then
    node "$CHECKER" 2>&1
    if [ $? -ne 0 ]; then
        echo ""
        echo "Commit blocked. Fix the reported paths and retry."
        exit 1
    fi
fi

exit 0
